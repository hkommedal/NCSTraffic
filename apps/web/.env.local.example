# Copy this file to .env.local and fill in real values

# Database
DATABASE_URL="file:./dev.db"

# Barentswatch AIS API (https://developer.barentswatch.no/)
BARENTSWATCH_CLIENT_ID="your-client-id"
BARENTSWATCH_CLIENT_SECRET="your-client-secret"

# Flightradar24 API (optional — basic data works without token)
FLIGHTRADAR24_ACCESS_TOKEN="your-access-token"
